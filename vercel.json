{
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/analyze",
      "dest": "server.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/profile.html",
      "dest": "/profile.html"
    }
  ]
}